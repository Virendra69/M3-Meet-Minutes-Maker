{
  "manifest_version": 3,
  "name": "Meet Minute Maker",
  "version": "1.0",
  "description": "Capture Google Meet captions and chat.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://meet.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
